VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# 启用 LiveKit 时填写
VITE_LIVEKIT_URL=wss://your-livekit-host

# 可选：如不填，前端默认回退到 ${VITE_SUPABASE_URL}/functions/v1/livekit-token
# VITE_LIVEKIT_TOKEN_ENDPOINT=https://your-api.example.com/rtc/token

# 以下变量用于 Supabase Edge Function livekit-token 部署环境
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

